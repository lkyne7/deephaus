# Supabase project URL (server-side name preferred; falls back to the public one).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Elevated Supabase key — NEVER expose this to the browser. The worker uses it
# to read queued jobs, write cards/media, and update job status across all users.
# Use either the legacy service_role JWT or the new default secret (sb_secret_…).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt-or-sb-secret-key
# SUPABASE_SECRET_KEY=sb_secret_...   # alternative name for the new secret key

# Optional: how often (ms) to poll for queued jobs. Default 5000.
ANKI_WORKER_POLL_MS=5000

# Optional: scratch dir for streaming packages to disk. Default OS tmp.
# Point this at a mounted volume on hosts where /tmp is small.
# ANKI_WORKER_TMPDIR=/data/tmp
