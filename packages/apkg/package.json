{
  "name": "@sluggo/apkg",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "sluggo-export-sample": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "export-sample": "node dist/cli.js"
  },
  "dependencies": {
    "@sluggo/shared": "workspace:*",
    "ankipack": "^0.1.0",
    "sql.js": "^1.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/sql.js": "^1.4.11",
    "typescript": "^5.8.3"
  }
}
