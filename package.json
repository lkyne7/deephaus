{
  "name": "deephaus",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:web": "pnpm --filter @deephaus/web dev",
    "dev:web:clean": "pnpm --filter @deephaus/web dev:clean",
    "dev:mobile": "pnpm --filter @deephaus/mobile dev",
    "mobile:ios": "pnpm --filter @deephaus/mobile ios:clear",
    "mobile:android": "pnpm --filter @deephaus/mobile android",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.15",
      "@types/react-dom": "19.2.3",
      "@supabase/supabase-js": "2.106.2"
    }
  }
}
